<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:layout_marginBottom="8dp"
    android:padding="12dp">

    <ImageView android:id="@+id/eventImage"
        android:layout_width="match_parent" android:layout_height="160dp"
        android:scaleType="centerCrop" android:src="@android:drawable/ic_menu_gallery"
        android:contentDescription="Event Image"/>

    <TextView android:id="@+id/eventTitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Event Title" android:textSize="17sp" android:textStyle="bold"
        android:textColor="#111111" android:layout_marginTop="8dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="4dp">
        <TextView android:id="@+id/eventDate"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Date" android:textSize="13sp"
            android:textColor="#555555"/>
        <TextView android:id="@+id/eventCategory"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tech" android:textSize="12sp" android:textColor="#FFFFFF"
            android:background="#1976D2" android:paddingStart="8dp" android:paddingEnd="8dp"
            android:paddingTop="2dp" android:paddingBottom="2dp"/>
    </LinearLayout>

    <TextView android:id="@+id/eventVenue"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Venue" android:textSize="13sp" android:textColor="#777777"
        android:layout_marginTop="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="4dp">
        <TextView android:id="@+id/eventSeats"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Seats: 0" android:textSize="13sp"
            android:textColor="#388E3C"/>
        <TextView android:id="@+id/eventPrice"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Free" android:textSize="14sp" android:textStyle="bold"
            android:textColor="#D32F2F"/>
    </LinearLayout>

</LinearLayout>