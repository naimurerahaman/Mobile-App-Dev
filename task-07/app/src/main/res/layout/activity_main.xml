<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Category Tab Bar -->
    <HorizontalScrollView
        android:id="@+id/categoryScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        android:scrollbars="none"
        android:layout_alignParentTop="true">

        <LinearLayout
            android:id="@+id/categoryLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button android:id="@+id/btnAll" android:layout_width="wrap_content"
                android:layout_height="36dp" android:text="All" android:layout_marginEnd="6dp"
                android:backgroundTint="#1976D2" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnNature" android:layout_width="wrap_content"
                android:layout_height="36dp" android:text="Nature" android:layout_marginEnd="6dp"
                android:backgroundTint="#444444" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnCity" android:layout_width="wrap_content"
                android:layout_height="36dp" android:text="City" android:layout_marginEnd="6dp"
                android:backgroundTint="#444444" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnAnimals" android:layout_width="wrap_content"
                android:layout_height="36dp" android:text="Animals" android:layout_marginEnd="6dp"
                android:backgroundTint="#444444" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnFood" android:layout_width="wrap_content"
                android:layout_height="36dp" android:text="Food" android:layout_marginEnd="6dp"
                android:backgroundTint="#444444" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTravel" android:layout_width="wrap_content"
                android:layout_height="36dp" android:text="Travel"
                android:backgroundTint="#444444" android:textColor="#FFFFFF"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Selection Toolbar (hidden initially) -->
    <LinearLayout
        android:id="@+id/selectionToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#D32F2F"
        android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="8dp"
        android:visibility="gone"
        android:layout_below="@id/categoryScrollView">

        <TextView
            android:id="@+id/selectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 selected"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

        <Button android:id="@+id/deleteButton"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Delete" android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF" android:layout_marginEnd="8dp"/>

        <Button android:id="@+id/shareSelectedButton"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Share" android:backgroundTint="#880E4F" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- GridView -->
    <GridView
        android:id="@+id/photoGrid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/selectionToolbar"
        android:numColumns="2"
        android:horizontalSpacing="4dp"
        android:verticalSpacing="4dp"
        android:padding="4dp"/>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Add Photo"/>

</RelativeLayout>