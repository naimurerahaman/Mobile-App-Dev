<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="#FFFFFF"
    android:layout_marginBottom="4dp">

    <!-- Product Image -->
    <ImageView
        android:id="@+id/productImage"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="Product Image"/>

    <!-- Product Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView android:id="@+id/productName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Product Name" android:textSize="15sp" android:textStyle="bold"
            android:textColor="#222222"/>

        <TextView android:id="@+id/productCategory"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Electronics" android:textSize="12sp" android:textColor="#1976D2"
            android:background="#E3F2FD" android:paddingStart="6dp" android:paddingEnd="6dp"
            android:paddingTop="2dp" android:paddingBottom="2dp" android:layout_marginTop="4dp"/>

        <RatingBar android:id="@+id/ratingBar"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:numStars="5" android:rating="4.0" android:isIndicator="true"
            android:layout_marginTop="4dp"/>

        <TextView android:id="@+id/productPrice"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="$29.99" android:textSize="16sp" android:textStyle="bold"
            android:textColor="#388E3C" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Add to Cart Button -->
    <Button android:id="@+id/addToCartBtn"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Add" android:backgroundTint="#1976D2" android:textColor="#FFFFFF"
        android:textSize="12sp" android:layout_gravity="center_vertical"/>

</LinearLayout>